# Block access to sensitive files when document root is the project root
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|artisan|version\.txt)$">
    Require all denied
</FilesMatch>

# Block access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^\.git - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^storage/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^bootstrap/ - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^app/ - [F,L]
    RewriteRule ^routes/ - [F,L]
    RewriteRule ^resources/ - [F,L]
    RewriteRule ^tests/ - [F,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
